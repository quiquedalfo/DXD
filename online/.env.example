# Copiá a .env.local en esta carpeta (online/) y completá valores del panel Supabase → Settings → API

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Opcional: para `npm run seed:fish` (crea personaje Fish por email sin SQL Editor).
# Supabase → Settings → API → service_role (secreta; nunca en el repo ni en el cliente móvil/web).
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cuentas de prueba (crealas en Authentication → Users o dejá que el script intente signUp)
# Contraseñas: mínimo 6 caracteres (requisito de Supabase Auth).
# Mails: usá un dominio “normal” (p. ej. @example.com). Supabase suele rechazar @*.test.local / @*.local.
MASTER_EMAIL=dxd-master@example.com
MASTER_PASSWORD=cambiar123
PLAYER_EMAIL=dxd-player@example.com
PLAYER_PASSWORD=cambiar123
